# ============================================================
# IAGestioneArte — API Keys Configuration
# ============================================================
# Copia questo file come .env e inserisci le tue chiavi.
# NON committare .env su Git!
#
# Per ottenere le chiavi gratuite:
#   OpenRouter → https://openrouter.ai/keys
#   Google     → https://aistudio.google.com/app/apikey
#   Groq       → https://console.groq.com/keys
#   Mistral    → https://console.mistral.ai/
#   HuggingFace→ https://huggingface.co/settings/tokens
# ============================================================

# PRIMARY LLM BACKEND (consigliato: OpenRouter — gratuito)
OPENROUTER_API_KEY=

# Google Gemini (per vision + LLM fallback)
GOOGLE_API_KEY=

# Groq (ultra-fast fallback)
GROQ_API_KEY=

# Mistral (reliable fallback)
MISTRAL_API_KEY=

# HuggingFace (inference API)
HF_TOKEN=

# DeepSeek (opzionale — vision analysis)
DEEPSEEK_API_KEY=

# Cohere (opzionale — reranker cloud)
COHERE_API_KEY=
