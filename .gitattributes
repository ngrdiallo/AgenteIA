# IAGestioneArte .gitattributes
# Tutti i file di testo: LF nel repository (Linux server target)
* text=auto eol=lf

# Python sempre LF
*.py text eol=lf

# Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.env text eol=lf
*.txt text eol=lf
*.md text eol=lf

# Shell scripts sempre LF
*.sh text eol=lf

# File binari: non toccare
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.pdf binary
*.db binary
*.sqlite binary
